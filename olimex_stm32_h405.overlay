/* olimex_stm32_h405.overlay */

/ {
    chosen {
        /* Route Zephyr console to USART1 (QEMU's primary serial0) */
        zephyr,console = &usart1;
    };
    aliases {
        serial0 = &usart1;
    };
};

/* ========================================================== */
/* 1. CLOCK FIX: Bypass the PLL completely. Run raw HSI.      */
/* QEMU does not toggle the PLLRDY bit, causing infinite hang.*/
/* ========================================================== */
&clk_hse { status = "disabled"; };
&pll { status = "disabled"; };
&clk_hsi { status = "okay"; };

&rcc {
    clocks = <&clk_hsi>;
    clock-frequency = <DT_FREQ_M(16)>;
};

/* ========================================================== */
/* 2. HARDWARE FIX: Align Console and Disable unused params   */
/* ========================================================== */
&usbotg_fs { status = "disabled"; };

/* Enable USART1 for QEMU's default -serial stdio port */
&usart1 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
};

&usart2 { status = "disabled"; };
&i2c1 { status = "disabled"; };
&rtc { status = "disabled"; };
&iwdg { status = "disabled"; };
