/* olimex_stm32_p405.overlay */

/ {
    chosen {
        /*
         * For QEMU netduinoplus2, keep console and shell on USART1.
         * This maps more reliably to the first QEMU -serial backend.
         */
        zephyr,console = &usart1;
        zephyr,shell-uart = &usart1;
    };

    aliases {
        serial0 = &usart1;
        serial1 = &usart2;

        /*
         * Keep this alias because the application code uses:
         * DEVICE_DT_GET(DT_ALIAS(cdc_acm_uart0))
         *
         * USB is disabled in QEMU, so map the alias to USART1.
         */
        cdc-acm-uart0 = &usart1;
    };
};

/* QEMU does not emulate physical USB for this board */
&usbotg_fs {
    status = "disabled";
};

/* Primary QEMU console UART */
&usart1 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
};

/* Secondary UART kept enabled for diagnostics */
&usart2 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
    pinctrl-names = "default";
};

&i2c1 {
    status = "okay";
    pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
    pinctrl-names = "default";
};

&rtc {
    status = "okay";
};

&iwdg {
    status = "okay";
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        storage_partition: partition@E0000 {
            label = "storage";
            reg = <0x000E0000 0x00020000>;
        };
    };
};
