/* olimex_stm32_h405.overlay */

/ {
    chosen {
        /* Route console to USART2 (QEMU's default serial0) */
        zephyr,console = &usart2;
    };
    aliases {
        serial0 = &usart2;
    };
};

/* =================================================================== */
/* CRITICAL FIX: Decouple from the physical crystal oscillator (HSE).  */
/* QEMU does not simulate crystals. Using HSI prevents the boot hang.  */
/* =================================================================== */
&clk_hse {
    status = "disabled";
};

&clk_hsi {
    status = "okay";
};

&pll {
    clocks = <&clk_hsi>;
    /* HSI runs at 16MHz. Divide by 16 to get 1MHz PLL input to match standard scaling */
    div-m = <16>; 
};

/* =================================================================== */

&usbotg_fs {
    status = "disabled";
};

&usart1 {
    status = "disabled";
};

&usart2 {
    status = "okay";
    current-speed = <115200>;
};

/* Keep unimplemented QEMU peripherals disabled for smoke boot */
&i2c1 { status = "disabled"; };
&rtc { status = "disabled"; };
&iwdg { status = "disabled"; };
